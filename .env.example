# Filtarr Configuration
# Copy this file to .env and adjust values as needed

# Server
FILTARR_PORT=9898
FILTARR_HOST=0.0.0.0
FILTARR_LOG_LEVEL=info

# Data directory (SQLite database, logs)
FILTARR_DATA_DIR=./data

# Node environment
NODE_ENV=production

# Authentication
# FILTARR_AUTH_MODE=forms
# FILTARR_SESSION_SECRET=replace-with-a-32+-character-secret-from-your-secret-store
# FILTARR_SESSION_MAX_AGE=86400000
# FILTARR_SESSION_COOKIE_NAME=filtarr.sid

# Optional OIDC configuration
# FILTARR_OIDC_ISSUER=https://id.example.com/realms/main
# FILTARR_OIDC_CLIENT_ID=filtarr
# FILTARR_OIDC_CLIENT_SECRET=replace-with-your-oidc-client-secret
# FILTARR_OIDC_CALLBACK_URL=https://filtarr.example.com/api/v1/auth/oidc/callback
# FILTARR_OIDC_SCOPES=openid,profile,email

# Dangerous features are opt-in
# FILTARR_ENABLE_CUSTOM_SCRIPTS=false

