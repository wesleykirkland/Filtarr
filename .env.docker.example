# Filtarr Docker Compose Environment Variables
# Copy this file to .env and adjust values as needed
# Docker Compose will automatically load .env file

# Build metadata (optional)
FILTARR_VERSION=0.1.0-dev
GIT_COMMIT=unknown
GIT_BRANCH=dev
BUILD_DATE=2026-03-14T00:00:00Z

# Server Configuration
NODE_ENV=production
FILTARR_PORT=9898
FILTARR_LOG_LEVEL=info

# Volume Paths
# Path to your downloads directory (mapped to /downloads in container)
DOWNLOADS_PATH=./downloads

# Encryption Secret (REQUIRED for production)
# Used to encrypt API keys stored in the database
# Generate with: openssl rand -base64 32
# IMPORTANT: Keep this secret safe and don't commit it to version control
FILTARR_SECRET=

# Authentication Configuration
# Leave commented to configure via web UI during initial setup
# Or pre-configure here for automated deployments

# Auth Mode: none, basic, forms, or oidc
# FILTARR_AUTH_MODE=forms

# Basic Auth Credentials (if using basic mode)
# FILTARR_AUTH_USERNAME=admin
# FILTARR_AUTH_PASSWORD=your-secure-password-here

# Forms Auth Session Configuration (if using forms mode)
# Session secret must be at least 32 characters
# Generate with: openssl rand -base64 32
# FILTARR_SESSION_SECRET=
# FILTARR_SESSION_MAX_AGE=86400000
# FILTARR_SESSION_COOKIE_NAME=filtarr.sid

# OIDC Configuration (if using OIDC mode)
# FILTARR_OIDC_ISSUER=https://id.example.com/realms/main
# FILTARR_OIDC_CLIENT_ID=filtarr
# FILTARR_OIDC_CLIENT_SECRET=your-oidc-client-secret
# FILTARR_OIDC_CALLBACK_URL=https://filtarr.example.com/api/v1/auth/oidc/callback
# FILTARR_OIDC_SCOPES=openid,profile,email

# CORS Origin (optional)
# FILTARR_CORS_ORIGIN=same-origin

# Custom Scripts (DANGEROUS - opt-in only)
# Enables JavaScript and shell script execution in filters
# See docs/security-custom-scripts.md before enabling
# FILTARR_ENABLE_CUSTOM_SCRIPTS=false

